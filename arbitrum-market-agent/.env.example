# Arbitrum RPC WebSocket URL
CHAIN_B_WS_URL=wss://arb1.arbitrum.io/websocket

# Arbitrum RPC HTTP URL (for fallback)
CHAIN_B_RPC_URL=https://arb1.arbitrum.io/rpc

# Camelot V3 Router Address
CAMELOT_ROUTER_ADDR=0xC873c1d8B534333fDb404C8C9dDd61fC1B2434E6

# Camelot V3 Pool Addresses (Arbitrum mainnet)
CAMELOT_ETH_USDC_POOL=0xb1026b8e7276e7ac75410f1fcbbe21796e8f7526

# Kafka Configuration
KAFKA_BROKERS=localhost:9092
KAFKA_TOPIC=market.arbitrum.price-snapshot
KAFKA_CLIENT_ID=arbitrum-market-agent

# Log Level
LOG_LEVEL=info
