# Monad MEV Testnet Deployment
# Copy to .env.testnet and fill in values

# ===========================================
# TESTNET RPC ENDPOINTS (GET REAL ONES)
# ===========================================
# Monad Testnet - get from https://docs.monad.xyz/testnet
MONAD_WS_URL=wss://testnet-rpc.monad.xyz/ws
MONAD_RPC_URL=https://testnet-rpc.monad.xyz

# Ethereum Sepolia (for cross-chain)
ETH_WS_URL=wss://eth-sepolia.g.alchemy.com/v3/YOUR_ALCHEMY_KEY
ETH_RPC_URL=https://eth-sepolia.g.alchemy.com/v3/YOUR_ALCHEMY_KEY

# ===========================================
# WALLET (NEW HD WALLET - $100 TESTNET)
# ===========================================
# Generate new wallet: cast wallet new
WALLET_PRIVATE_KEY=0x...your testnet private key...

# ===========================================
# CONTRACTS (GET REAL ONES)
# ===========================================
# Kuru on Monad testnet
KURU_ETH_USDC_ADDR=0x...
KURU_MON_USDC_ADDR=0x...

# Uniswap V3 Sepolia
UNI_ETH_USDC_005_ADDR=0x...

# ===========================================
# KAFKA
# ===========================================
KAFKA_BROKERS=kafka:29092

# ===========================================
# RISK LIMITS (CONSERVATIVE)
# ===========================================
MAX_POSITION_USD=50
EV_MIN_THRESHOLD=10
DRY_RUN=false

# ===========================================
# ALERTS
# ===========================================
DISCORD_WEBHOOK=
SLACK_WEBHOOK=
