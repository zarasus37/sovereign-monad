# Base RPC WebSocket URL
BASE_WS_URL=wss://ws.base.org
# Or use CHAIN_A_WS_URL (for docker-compose compatibility)

# Base RPC HTTP URL (optional, for write operations)
BASE_RPC_URL=https://mainnet.base.org

# Aerodrome Contract Addresses (Base mainnet)
AERODROME_ROUTER_ADDR=0x1f4c763bE1d762D981dDa1ea4d3302EEb4F2A23F
AERODROME_ETH_USDC_POOL=0xb2cc224c1c9fee385f8ad6a55b4d94e92359dc59

# Kafka Configuration
KAFKA_BROKERS=localhost:9092
KAFKA_TOPIC=market.base.price-snapshot

# Optional: Kafka client ID
KAFKA_CLIENT_ID=base-market-agent

# Log Level (debug, info, warn, error)
LOG_LEVEL=info
