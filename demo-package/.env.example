# Demo Package Environment Template
# Copy this to .env and customize

# Kafka Configuration
KAFKA_BROKERS=localhost:29092

# Demo Market Agent A Settings
DEMO_PRICE_A=2500.00
DEMO_VENUE_SPREAD_A_BPS=8
DEMO_VOLATILITY_A_BPS=14
DEMO_DRIFT_A_BPS_PER_TICK=0.5
DEMO_WAVE_A_BPS=12

# Demo Market Agent B Settings
DEMO_PRICE_B=2502.50
DEMO_VENUE_SPREAD_B_BPS=10
DEMO_VOLATILITY_B_BPS=16
DEMO_DRIFT_B_BPS_PER_TICK=0.3
DEMO_WAVE_B_BPS=16

# Spread detection threshold (basis points)
DEMO_SPREAD_THRESHOLD_BPS=1
DEMO_BRIDGE_DELAY_MS=4000
DEMO_SIZE_SUGGESTION_USD=1000

# Publish interval in milliseconds
PUBLISH_INTERVAL_MS=2000

# Demo risk thresholds
DEMO_RISK_FIXED_COST_BPS=8
DEMO_RISK_MIN_EFFECTIVE_SPREAD_BPS=12
DEMO_EV_MIN_THRESHOLD=0
DEMO_SHARPE_LIKE_THRESHOLD=0.15
DEMO_MAX_TAIL_LOSS_PERCENT=20
DEMO_GAS_COST_USD=6.50

# Log level (debug, info, warn, error)
LOG_LEVEL=info
