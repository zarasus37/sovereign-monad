{
  "name": "speech-gateway",
  "version": "0.1.0",
  "private": true,
  "description": "Azure Speech-backed gateway for speech-to-text, text-to-speech, and speech-aware reply handling",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "ts-node src/index.ts",
    "test": "node --test tests/*.test.js"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "dependencies": {
    "dotenv": "^17.4.0",
    "express": "^5.2.1",
    "microsoft-cognitiveservices-speech-sdk": "^1.49.0",
    "pino": "^10.3.1"
  },
  "devDependencies": {
    "@types/express": "^5.0.3",
    "@types/node": "^24.7.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  }
