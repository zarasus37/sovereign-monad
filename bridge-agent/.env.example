# Kafka Configuration
KAFKA_BROKERS=localhost:9092
KAFKA_CLIENT_ID=bridge-agent

# Topics
INPUT_TOPIC=bridge.transfer-request
OUTPUT_TOPIC=bridge.transfer-result
QUOTES_TOPIC=bridge.quotes

# RPC URLs
BASE_RPC_URL=https://mainnet.base.org
ARBITRUM_RPC_URL=https://arb1.arbitrum.io/rpc

# Private Key (for signing transactions)
PRIVATE_KEY=

# Across SpokePool Addresses (defaults provided if not set)
ACROSS_SPOKEPOOL_BASE=0x11984dc4465481512eb5b777E44061C158CF2259
ACROSS_SPOKEPOOL_ARBITRUM=0xB88690461dDbaB6f04D39C1eB3B8E805e5bF44f6

# Execution Settings
DRY_RUN=true
MAX_SLIPPAGE_BPS=100

# Logging
LOG_LEVEL=info
