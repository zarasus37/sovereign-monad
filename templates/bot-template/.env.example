# Environment Configuration

# Kafka
KAFKA_BROKERS=kafka:29092

# Input/Output Topics
INPUT_TOPIC=execution.execution-plan
OUTPUT_TOPIC=execution.execution-result

# Chain A (Base)
CHAIN_A_RPC_URL=
CHAIN_A_NAME=base

# Chain B (Arbitrum)  
CHAIN_B_RPC_URL=
CHAIN_B_NAME=arbitrum

# Wallet
PRIVATE_KEY=

# Execution Mode
DRY_RUN=true

# Trading Parameters
MIN_SPREAD_BPS=5
MAX_SLIPPAGE_BPS=50
MIN_POSITION_SIZE=100
MAX_POSITION_SIZE=10000

# Risk Parameters
MAX_EXPOSURE=100000
MAX_DAILY_LOSS=5000

# Logging
LOG_LEVEL=info
