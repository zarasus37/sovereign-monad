# Monad MEV System - Mainnet DRY_RUN Environment Template
# Copy to .env and fill in the missing values.

# ===== MONAD MAINNET =====
MONAD_WS_URL=wss://wss.monad-rpc.huginn.tech
MONAD_RPC_URL=https://rpc.monad.xyz

# ===== KURU MAINNET CONTRACTS =====
KURU_ROUTER_ADDR=0xb3e6778480b2E488385E8205eA05E20060B813cb
KURU_WETH_MON_ADDR=
KURU_WETH_AUSD_ADDR=0xcd8cc5f5b6f744403ad96a8802e050bba1aba37e
KURU_MON_USDC_ADDR=0x065C9d28E428A0db40191a54d33d5b7c71a9C394
KURU_ETH_USDC_ADDR=
KURU_STRESS_POOL_ADDR=0x065C9d28E428A0db40191a54d33d5b7c71a9C394
USDC_TOKEN_ADDRESS=0x754704bc059f8c67012fed69bc8a327a5aafb603

# ===== ETH MAINNET =====
ETH_WS_URL=wss://eth-mainnet.g.alchemy.com/v2/YOUR_ALCHEMY_KEY
ETH_RPC_URL=https://eth-mainnet.g.alchemy.com/v2/YOUR_ALCHEMY_KEY
UNI_V3_ETH_USDC_POOL=0x88e6a0c2ddd26feeb64f039a2c41296fcb3f5640

# ===== WALLET =====
WALLET_ADDRESS=0xYOUR_WALLET_ADDRESS
WALLET_PRIVATE_KEY=0xYOUR_PRIVATE_KEY

# ===== RISK THRESHOLDS =====
MIN_SPREAD_BPS=15
MIN_LIQUIDITY_10BPS_USD=5000
MIN_CAPACITY_USD=10000
MIN_NOTIONAL_CAPACITY=500
MIN_EV_PCT=0.15
DRY_RUN=true
MAX_SNAPSHOT_AGE_MS=60000
KAFKA_BROKERS=localhost:9092
MAX_SINGLE_TRADE_PERCENT=0.1
MAX_BRIDGE_EXPOSURE_PERCENT=25

# ===== OPTIONAL ALERTING =====
DISCORD_WEBHOOK_URL=
SLACK_WEBHOOK_URL=

# ===== OPTIONAL FLASHBOTS =====
USE_FLASHBOTS=true
FLASHBOTS_RELAY_URL=https://relay.flashbots.net
