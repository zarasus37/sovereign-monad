# Base/Arbitrum MEV System - Mainnet DRY_RUN Environment Template
# Copy to .env and fill in the missing values.

# ===== BASE MAINNET =====
BASE_WS_URL=wss://base-rpc.publicnode.com
BASE_RPC_URL=https://mainnet.base.org

# ===== ARBITRUM MAINNET =====
ARBITRUM_WS_URL=wss://arbitrum-one-rpc.publicnode.com
ARBITRUM_RPC_URL=https://arb1.arbitrum.io/rpc

# ===== AERODROME (BASE) CONTRACTS =====
AERODROME_ROUTER_ADDR=0x1f4c763bE1d762D981dDa1ea4d3302EEb4F2A23F
AERODROME_ETH_USDC_POOL=0xb2cc224c1c9fee385f8ad6a55b4d94e92359dc59
AERODROME_USDC_ETH_POOL=
AERODROME_MON_USDC_POOL=

# ===== CAMELOT (ARBITRUM) CONTRACTS =====
CAMELOT_ROUTER_ADDR=0xC873c1d8B534333fDb404C8C9dDd61fC1B2434E6
CAMELOT_ETH_USDC_POOL=0xb1026b8e7276e7ac75410f1fcbbe21796e8f7526
CAMELOT_USDC_ETH_POOL=

# ===== ACROSS BRIDGE =====
ACROSS_SPOKEPOOL_BASE=0x11984dc4465481512eb5b777E44061C158CF2259
ACROSS_SPOKEPOOL_ARBITRUM=0xB88690461dDbaB6f04D39C1eB3B8E805e5bF44f6

# ===== WALLET =====
WALLET_ADDRESS=0xYOUR_WALLET_ADDRESS
WALLET_PRIVATE_KEY=0xYOUR_PRIVATE_KEY

# ===== RISK THRESHOLDS =====
MIN_SPREAD_BPS=12
MIN_LIQUIDITY_10BPS_USD=750
MIN_CAPACITY_USD=3000
MIN_SIZE_USD=250
EV_MIN_THRESHOLD=10
SHARPE_LIKE_THRESHOLD=0.3
MAX_TAIL_LOSS_PERCENT=30
RISK_FIXED_COST_BPS=8
RISK_MIN_EFFECTIVE_SPREAD_BPS=12
MIN_NOTIONAL_CAPACITY=500
MIN_EV_PCT=0.15
DRY_RUN=true
MAX_SNAPSHOT_AGE_MS=60000
KAFKA_BROKERS=localhost:9092
MAX_SINGLE_TRADE_PERCENT=10
MAX_CHAIN_EXPOSURE_PERCENT=80
MAX_BRIDGE_EXPOSURE_PERCENT=25
MAX_SLIPPAGE_BPS=50

# ===== GUARDED-LIVE REFERENCE =====
# For the proposed first funded profile, see docs/GUARDED-LIVE-PROFILE.md

# ===== OPTIONAL ALERTING =====
DISCORD_WEBHOOK_URL=
SLACK_WEBHOOK_URL=
MIN_ALERT_SPREAD_BPS=50
MAX_POSITION_ALERT_USD=5000
ALERT_COOLDOWN_MS=30000

# ===== OPTIONAL FLASHBOTS =====
USE_FLASHBOTS=false
FLASHBOTS_RELAY_URL=
