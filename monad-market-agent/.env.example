# Monad RPC WebSocket URL
MONAD_WS_URL=wss://monad-mainnet.quiknode.pro/<your-key>/

# KuruExchange Contract Addresses (Monad mainnet)
KURU_ETH_USDC_ADDR=0x1234567890abcdef1234567890abcdef12345678
KURU_MON_USDC_ADDR=0xabcdef1234567890abcdef1234567890abcdef12

# Kafka Configuration
KAFKA_BROKERS=localhost:9092
KAFKA_TOPIC=market.monad.price-snapshot

# Optional: Kafka client ID
KAFKA_CLIENT_ID=monad-market-agent

# Log Level (debug, info, warn, error)
LOG_LEVEL=info
