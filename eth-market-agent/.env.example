# Ethereum RPC WebSocket URL
ETH_WS_URL=wss://mainnet.infura.io/ws/v3/<your-project-id>

# Uniswap V3 Pool Addresses (Ethereum mainnet)
UNI_ETH_USDC_005_ADDR=0x88e6a0c2ddd26feeb64f039a2c41296fcb3f5640
UNI_MON_ETH_ADDR=<mon-eth-pool-address>

# Kafka Configuration
KAFKA_BROKERS=localhost:9092
KAFKA_TOPIC=market.eth.price-snapshot
KAFKA_CLIENT_ID=eth-market-agent

# Log Level
LOG_LEVEL=info
