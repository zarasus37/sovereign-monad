LOG_LEVEL=info
ORGAN_RUNTIME_CONFIG=./config/runtime.json
ORGAN_RUNTIME_MODE=analysis

# Azure Cosmos DB — Hepar persistence layer
# Copy this file to .env and fill in real values. Never commit .env.
COSMOS_ENDPOINT=https://<your-account>.documents.azure.com:443/
COSMOS_KEY=<your-primary-or-secondary-key>
COSMOS_DB_NAME=hepar
COSMOS_CONTAINER_OPPORTUNITIES=opportunities
COSMOS_CONTAINER_MANDATES=mandates
COSMOS_CONTAINER_SIGNALS=hepar-signals
